# App
PORT=3000
SESSION_SECRET=ganti_ini_dengan_string_random_panjang
NODE_ENV=development

# Brand
BRAND_NAME=ZarHost

# Payment Gateway (https://fr3newera.com/api/v1)
PAYMENT_API_KEY=AO_xxxxx221220241234abcdefghij
PAYMENT_BASE_URL=https://fr3newera.com/api/v1

# CloudPanel VPS (untuk provisioning otomatis via cloudpanel-sdk)
CLOUDPANEL_HOST=1.2.3.4
CLOUDPANEL_USER=root
CLOUDPANEL_PASSWORD=yourVpsPassword
CLOUDPANEL_PORT=22

# Nameserver (ditampilkan ke user untuk arahkan domain)
NS1=ns1.zarhost.id
NS2=ns2.zarhost.id

# Admin default (seed otomatis saat startup pertama)
ADMIN_EMAIL=admin@zarhost.id
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Administrator

# Mode dev: skip pemanggilan SSH ke CloudPanel (untuk testing tanpa VPS)
# Set ke "true" agar provisioning hanya generate kredensial dummy tanpa SSH.
SKIP_CLOUDPANEL=false
