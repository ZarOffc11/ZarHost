<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1.0" />
<title><%= typeof title !== 'undefined' ? title : 'Hosting' %> · <%= brand %></title>
<meta name="description" content="<%= brand %> - Layanan hosting cepat, aman, dan terpercaya berbasis CloudPanel dengan provisioning otomatis." />

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<!-- Tailwind CSS Play CDN -->
<script src="https://cdn.tailwindcss.com"></script>
<script>
tailwind.config = {
  darkMode: 'class',
  theme: {
    extend: {
      fontFamily: {
        display: ['Poppins', 'system-ui', 'sans-serif'],
        body:    ['Inter',   'system-ui', 'sans-serif'],
      },
      colors: {
        bg:        '#07090C',
        bg2:       '#0B0D12',
        card:      '#0F1318',
        card2:     '#141921',
        card3:     '#1A2029',
        border:    '#1F2730',
        border2:   '#2A3340',
        primary:   '#10B981',
        primary2:  '#34D399',
        primary3:  '#6EE7B7',
        emerald:   '#10B981',
        teal:      '#14B8A6',
        gold:      '#D4AF37',
        gold2:     '#F5C451',
        danger:    '#EF4444',
        warn:      '#F59E0B',
        ink:       '#F1F5F9',
        ink2:      '#94A3B8',
        muted:     '#475569',
      },
      boxShadow: {
        glow:      '0 0 24px rgba(16, 185, 129, 0.22)',
        glowHover: '0 0 40px rgba(16, 185, 129, 0.42)',
        gold:      '0 0 20px rgba(212, 175, 55, 0.25)',
        soft:      '0 4px 24px rgba(0, 0, 0, 0.35)',
      },
      backgroundImage: {
        brand:      'linear-gradient(135deg, #10B981 0%, #14B8A6 100%)',
        brandDark:  'linear-gradient(135deg, #065F46 0%, #0F766E 100%)',
        gold:       'linear-gradient(135deg, #D4AF37 0%, #F5C451 100%)',
      },
      borderRadius: {
        '2xl': '1rem',
      },
    },
  },
};
</script>

<!-- Font Awesome 6 -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<!-- Material Icons -->
<link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
<!-- AOS -->
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
<!-- SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<!-- tsParticles -->
<script src="https://cdn.jsdelivr.net/npm/tsparticles@2.12.0/tsparticles.bundle.min.js"></script>

<link rel="stylesheet" href="/static/css/custom.css" />
</head>
