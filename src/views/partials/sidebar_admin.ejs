<%
  const _sidebarAdminLinks = [
    { href: '/admin',              key: 'home',         icon: 'fa-gauge-high',    label: 'Dashboard' },
    { href: '/admin/users',        key: 'users',        icon: 'fa-users',         label: 'Users' },
    { href: '/admin/hostings',     key: 'hostings',     icon: 'fa-server',        label: 'Hostings' },
    { href: '/admin/transactions', key: 'transactions', icon: 'fa-receipt',       label: 'Transaksi' },
    { href: '/admin/packages',     key: 'packages',     icon: 'fa-box',           label: 'Paket' },
    { href: '/admin/vps-config',   key: 'vps',          icon: 'fa-network-wired', label: 'VPS Config' },
  ];
%>

<!-- Desktop sidebar -->
<aside class="hidden lg:block lg:sticky lg:top-20 self-start lg:w-64 shrink-0">
  <%- include('_sidebar_admin_body', { links: _sidebarAdminLinks }) %>
</aside>

<!-- Mobile drawer -->
<div id="sidebar-mobile" class="sidebar-mobile lg:hidden">
  <div class="backdrop" data-close-sidebar></div>
  <div class="panel">
    <div class="flex items-center justify-between mb-3">
      <a href="/admin" class="flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-gold/20 border border-gold grid place-items-center">
          <i class="fa-solid fa-shield-halved text-gold text-sm"></i>
        </span>
        <span class="font-display font-extrabold text-lg text-ink">Admin</span>
      </a>
      <button type="button" data-close-sidebar class="p-2 rounded-lg text-ink2 hover:text-ink hover:bg-card2">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <%- include('_sidebar_admin_body', { links: _sidebarAdminLinks }) %>
  </div>
</div>

<script>
  (function () {
    var drawer = document.getElementById('sidebar-mobile');
    var trigger = document.getElementById('nav-sidebar-toggle');
    if (trigger && drawer) trigger.addEventListener('click', function () { drawer.classList.add('open'); });
    document.querySelectorAll('[data-close-sidebar]').forEach(function (el) {
      el.addEventListener('click', function () { drawer && drawer.classList.remove('open'); });
    });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') drawer && drawer.classList.remove('open'); });
  })();
</script>
