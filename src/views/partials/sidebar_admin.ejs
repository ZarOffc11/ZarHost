<aside class="lg:sticky lg:top-20 self-start lg:w-64 w-full shrink-0">
  <div class="rounded-2xl border border-border bg-card p-4">
    <div class="flex items-center gap-3 px-2 py-3 mb-3 border-b border-border">
      <div class="w-10 h-10 rounded-full bg-gold/20 border border-gold grid place-items-center text-gold font-display font-bold">
        <i class="fa-solid fa-shield-halved"></i>
      </div>
      <div class="min-w-0">
        <div class="font-display font-semibold text-ink truncate">Admin</div>
        <div class="text-xs text-ink2 truncate"><%= currentUser.email %></div>
      </div>
    </div>
    <nav class="space-y-1 text-sm">
      <a href="/admin"               class="flex items-center gap-3 px-3 py-2 rounded-xl <%= activeMenu==='home'         ? 'bg-brand text-white shadow-glow' : 'text-ink2 hover:text-ink hover:bg-card2' %>"><i class="fa-solid fa-gauge-high w-4"></i> Dashboard</a>
      <a href="/admin/users"         class="flex items-center gap-3 px-3 py-2 rounded-xl <%= activeMenu==='users'        ? 'bg-brand text-white shadow-glow' : 'text-ink2 hover:text-ink hover:bg-card2' %>"><i class="fa-solid fa-users w-4"></i> Users</a>
      <a href="/admin/hostings"      class="flex items-center gap-3 px-3 py-2 rounded-xl <%= activeMenu==='hostings'     ? 'bg-brand text-white shadow-glow' : 'text-ink2 hover:text-ink hover:bg-card2' %>"><i class="fa-solid fa-server w-4"></i> Hostings</a>
      <a href="/admin/transactions"  class="flex items-center gap-3 px-3 py-2 rounded-xl <%= activeMenu==='transactions' ? 'bg-brand text-white shadow-glow' : 'text-ink2 hover:text-ink hover:bg-card2' %>"><i class="fa-solid fa-receipt w-4"></i> Transaksi</a>
      <a href="/admin/packages"      class="flex items-center gap-3 px-3 py-2 rounded-xl <%= activeMenu==='packages'     ? 'bg-brand text-white shadow-glow' : 'text-ink2 hover:text-ink hover:bg-card2' %>"><i class="fa-solid fa-box w-4"></i> Paket</a>
      <a href="/admin/vps-config"    class="flex items-center gap-3 px-3 py-2 rounded-xl <%= activeMenu==='vps'          ? 'bg-brand text-white shadow-glow' : 'text-ink2 hover:text-ink hover:bg-card2' %>"><i class="fa-solid fa-network-wired w-4"></i> VPS Config</a>
      <a href="/dashboard"           class="flex items-center gap-3 px-3 py-2 rounded-xl text-ink2 hover:text-ink hover:bg-card2"><i class="fa-solid fa-arrow-left-long w-4"></i> Ke User Dashboard</a>
      <form method="POST" action="/auth/logout">
        <button class="w-full flex items-center gap-3 px-3 py-2 rounded-xl text-ink2 hover:text-danger hover:bg-card2"><i class="fa-solid fa-right-from-bracket w-4"></i> Keluar</button>
      </form>
    </nav>
  </div>
</aside>
