<%
  // Public nav links — dipakai di desktop (center) dan mobile drawer
  const _publicNav = [
    { href: '/',         match: '/',         label: 'Beranda', icon: 'fa-house' },
    { href: '/pricing',  match: '/pricing',  label: 'Paket',   icon: 'fa-cubes' },
    { href: '/#fitur',   match: null,        label: 'Fitur',   icon: 'fa-bolt' },
    { href: '/#faq',     match: null,        label: 'FAQ',     icon: 'fa-circle-question' },
  ];
  const _showSidebar = (typeof showSidebar !== 'undefined' && showSidebar);
%>

<nav class="fixed top-0 inset-x-0 z-50 backdrop-blur-2xl bg-bg/85 border-b border-border">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between gap-2 h-16">

      <!-- LEFT: hamburger + brand -->
      <div class="flex items-center gap-1 min-w-0">
        <!-- Hamburger: di dashboard/admin pages buka sidebar drawer; di public buka public nav drawer -->
        <button id="nav-menu-btn" type="button" class="<%= _showSidebar ? 'lg:hidden' : 'md:hidden' %> p-2 rounded-lg text-ink hover:bg-card2 transition shrink-0" aria-label="Menu">
          <i class="fa-solid fa-bars text-lg"></i>
        </button>

        <a href="/" class="flex items-center gap-2 group min-w-0">
          <span class="w-9 h-9 rounded-xl bg-brand grid place-items-center shadow-glow group-hover:shadow-glowHover transition shrink-0">
            <i class="fa-solid fa-cube text-white text-base"></i>
          </span>
          <span class="font-display font-extrabold text-xl text-ink tracking-tight truncate hidden xs:block sm:block"><%= brand %></span>
        </a>
      </div>

      <!-- CENTER: Public main nav (desktop only) -->
      <div class="hidden md:flex items-center gap-1">
        <% _publicNav.forEach(function(n) { %>
          <a href="<%= n.href %>" class="px-3 lg:px-4 py-2 rounded-full text-sm font-medium <%= n.match && path === n.match ? 'text-ink bg-card2 border border-border' : 'text-ink2 hover:text-ink hover:bg-card2' %> transition"><%= n.label %></a>
        <% }) %>
      </div>

      <!-- RIGHT: Profile / CTA -->
      <div class="flex items-center gap-2 shrink-0">
        <% if (currentUser) { %>
          <% if (currentUser.role === 'admin') { %>
            <a href="/admin" title="Admin Panel" class="hidden sm:inline-flex items-center gap-1.5 px-3 py-2 rounded-full text-xs font-semibold text-gold border border-gold/40 bg-gold/5 hover:bg-gold/10 transition">
              <i class="fa-solid fa-shield-halved"></i> <span class="hidden lg:inline">Admin</span>
            </a>
          <% } %>

          <!-- Avatar button + dropdown / mobile sheet -->
          <div class="relative" id="nav-avatar-wrap">
            <button id="nav-avatar-btn" type="button" aria-label="Profile menu"
                    class="flex items-center gap-2 pl-1 pr-1 sm:pr-3 py-1 rounded-full border border-border bg-card2 hover:border-primary/60 hover:bg-card3 transition">
              <img src="<%= currentUser.avatar %>" alt="<%= currentUser.name %>"
                   class="w-9 h-9 rounded-full object-cover bg-card border border-border shrink-0"
                   referrerpolicy="no-referrer"
                   onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(currentUser.name||'U') %>&background=10B981&color=ffffff&bold=true&size=128';" />
              <span class="hidden sm:block text-sm font-medium text-ink max-w-[120px] truncate"><%= currentUser.name %></span>
              <i class="fa-solid fa-chevron-down text-xs text-ink2 hidden sm:block"></i>
            </button>

            <!-- Dropdown / mobile sheet -->
            <div id="nav-avatar-menu" class="avatar-menu">
              <!-- Header -->
              <div class="p-4 border-b border-border flex items-center gap-3">
                <img src="<%= currentUser.avatar %>" alt="<%= currentUser.name %>"
                     class="w-12 h-12 rounded-full object-cover bg-card border border-border shrink-0"
                     referrerpolicy="no-referrer"
                     onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(currentUser.name||'U') %>&background=10B981&color=ffffff&bold=true&size=128';" />
                <div class="min-w-0 flex-1">
                  <div class="font-display font-semibold text-ink truncate"><%= currentUser.name %></div>
                  <div class="text-xs text-ink2 truncate"><%= currentUser.email %></div>
                  <% if (currentUser.role === 'admin') { %>
                    <span class="badge badge-gold mt-1.5"><i class="fa-solid fa-shield-halved text-[10px]"></i> Admin</span>
                  <% } %>
                </div>
                <button type="button" data-close-avatar class="sm:hidden p-2 rounded-lg text-ink2 hover:bg-card2" aria-label="Close">
                  <i class="fa-solid fa-xmark"></i>
                </button>
              </div>

              <!-- Body links -->
              <div class="p-2 space-y-0.5 text-sm">
                <a href="/dashboard"          class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-ink hover:bg-card2 transition"><i class="fa-solid fa-gauge-high w-5 text-primary2"></i> Dashboard</a>
                <a href="/dashboard/hosting"  class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-ink hover:bg-card2 transition"><i class="fa-solid fa-globe w-5 text-primary2"></i> Hosting Saya</a>
                <a href="/dashboard/history"  class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-ink hover:bg-card2 transition"><i class="fa-solid fa-clock-rotate-left w-5 text-primary2"></i> Riwayat Transaksi</a>
                <a href="/dashboard/profile"  class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-ink hover:bg-card2 transition"><i class="fa-solid fa-user w-5 text-primary2"></i> Profil</a>
                <a href="/pricing"            class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-ink hover:bg-card2 transition"><i class="fa-solid fa-cart-plus w-5 text-primary2"></i> Beli Paket Baru</a>
                <% if (currentUser.role === 'admin') { %>
                  <div class="border-t border-border my-1"></div>
                  <a href="/admin" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gold hover:bg-gold/10 transition"><i class="fa-solid fa-shield-halved w-5"></i> Admin Panel</a>
                <% } %>
                <div class="border-t border-border my-1"></div>
                <form method="POST" action="/auth/logout">
                  <button type="submit" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-ink2 hover:text-danger hover:bg-danger/10 transition">
                    <i class="fa-solid fa-right-from-bracket w-5"></i> Keluar
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% } else { %>
          <a href="/auth/login"    class="hidden sm:inline-flex items-center px-4 py-2 rounded-full text-sm font-medium text-ink2 hover:text-ink hover:bg-card2 transition">Masuk</a>
          <a href="/auth/register" class="inline-flex items-center px-4 py-2 rounded-full text-sm font-semibold text-white bg-brand shadow-glow hover:shadow-glowHover transition whitespace-nowrap">
            <span class="hidden sm:inline">Daftar</span>
            <span class="sm:hidden"><i class="fa-solid fa-user-plus"></i></span>
          </a>
        <% } %>
      </div>
    </div>
  </div>
</nav>
<div class="h-16"></div>

<!-- Public mobile drawer (used when NOT showing sidebar drawer i.e. on public pages) -->
<% if (!_showSidebar) { %>
  <div id="public-mobile-nav" class="sidebar-mobile md:hidden">
    <div class="backdrop" data-close-public-nav></div>
    <div class="panel">
      <div class="flex items-center justify-between mb-4">
        <a href="/" class="flex items-center gap-2">
          <span class="w-9 h-9 rounded-xl bg-brand grid place-items-center shadow-glow">
            <i class="fa-solid fa-cube text-white text-sm"></i>
          </span>
          <span class="font-display font-extrabold text-lg text-ink"><%= brand %></span>
        </a>
        <button type="button" data-close-public-nav class="p-2 rounded-lg text-ink2 hover:text-ink hover:bg-card2">
          <i class="fa-solid fa-xmark text-lg"></i>
        </button>
      </div>

      <% if (currentUser) { %>
        <div class="mb-4 p-3 rounded-xl border border-border bg-card2 flex items-center gap-3">
          <img src="<%= currentUser.avatar %>" alt="<%= currentUser.name %>"
               class="w-11 h-11 rounded-full object-cover bg-card border border-border shrink-0"
               referrerpolicy="no-referrer" />
          <div class="min-w-0 flex-1">
            <div class="font-display font-semibold text-ink truncate text-sm"><%= currentUser.name %></div>
            <div class="text-xs text-ink2 truncate"><%= currentUser.email %></div>
          </div>
        </div>
      <% } %>

      <div class="text-[11px] text-muted uppercase tracking-wider font-bold mb-2 px-1">Navigasi</div>
      <nav class="space-y-1 mb-4">
        <% _publicNav.forEach(function(n) { %>
          <a href="<%= n.href %>" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium <%= n.match && path === n.match ? 'text-ink bg-card2 border border-border' : 'text-ink2 hover:text-ink hover:bg-card2' %>"><i class="fa-solid <%= n.icon %> w-5 text-primary2"></i> <%= n.label %></a>
        <% }) %>
      </nav>

      <% if (currentUser) { %>
        <div class="text-[11px] text-muted uppercase tracking-wider font-bold mb-2 px-1">Akun Saya</div>
        <nav class="space-y-1 mb-4">
          <a href="/dashboard"          class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-ink hover:bg-card2"><i class="fa-solid fa-gauge-high w-5 text-primary2"></i> Dashboard</a>
          <a href="/dashboard/hosting"  class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-ink hover:bg-card2"><i class="fa-solid fa-globe w-5 text-primary2"></i> Hosting Saya</a>
          <a href="/dashboard/history"  class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-ink hover:bg-card2"><i class="fa-solid fa-clock-rotate-left w-5 text-primary2"></i> Riwayat Transaksi</a>
          <a href="/dashboard/profile"  class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-ink hover:bg-card2"><i class="fa-solid fa-user w-5 text-primary2"></i> Profil</a>
          <% if (currentUser.role === 'admin') { %>
            <a href="/admin" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-gold hover:bg-gold/10"><i class="fa-solid fa-shield-halved w-5"></i> Admin Panel</a>
          <% } %>
        </nav>
        <form method="POST" action="/auth/logout">
          <button type="submit" class="w-full flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl border border-danger/40 text-danger hover:bg-danger/10 transition text-sm font-medium">
            <i class="fa-solid fa-right-from-bracket"></i> Keluar
          </button>
        </form>
      <% } else { %>
        <div class="space-y-2 pt-2 border-t border-border">
          <a href="/auth/login"    class="block px-4 py-2.5 rounded-xl border border-border text-center text-ink hover:bg-card2 text-sm font-medium">Masuk</a>
          <a href="/auth/register" class="block px-4 py-2.5 rounded-xl bg-brand text-white text-center shadow-glow text-sm font-semibold">Daftar Sekarang</a>
        </div>
      <% } %>
    </div>
  </div>
<% } %>

<script>
  (function () {
    // Avatar dropdown / mobile sheet
    var avBtn  = document.getElementById('nav-avatar-btn');
    var avMenu = document.getElementById('nav-avatar-menu');
    if (avBtn && avMenu) {
      avBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        avMenu.classList.toggle('open');
      });
      document.addEventListener('click', function (e) {
        if (!avMenu.contains(e.target) && !avBtn.contains(e.target)) avMenu.classList.remove('open');
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') avMenu.classList.remove('open');
      });
      document.querySelectorAll('[data-close-avatar]').forEach(function (el) {
        el.addEventListener('click', function () { avMenu.classList.remove('open'); });
      });
    }

    // Hamburger menu — opens either sidebar drawer (dashboard/admin) OR public nav drawer
    var menuBtn = document.getElementById('nav-menu-btn');
    if (menuBtn) {
      menuBtn.addEventListener('click', function () {
        var sb = document.getElementById('sidebar-mobile');
        var pn = document.getElementById('public-mobile-nav');
        if (sb) { sb.classList.add('open'); }
        else if (pn) { pn.classList.add('open'); }
      });
    }
    document.querySelectorAll('[data-close-public-nav]').forEach(function (el) {
      el.addEventListener('click', function () {
        var pn = document.getElementById('public-mobile-nav');
        if (pn) pn.classList.remove('open');
      });
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        var pn = document.getElementById('public-mobile-nav');
        if (pn) pn.classList.remove('open');
      }
    });
  })();
</script>
