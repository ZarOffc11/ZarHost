<nav class="fixed top-0 inset-x-0 z-50 backdrop-blur-2xl bg-bg/70 border-b border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2 group">
        <span class="w-9 h-9 rounded-xl bg-brand grid place-items-center shadow-glow group-hover:shadow-glowHover transition">
          <i class="fa-solid fa-cube text-white text-base"></i>
        </span>
        <span class="font-display font-extrabold text-xl text-ink tracking-tight"><%= brand %></span>
      </a>

      <div class="hidden md:flex items-center gap-1">
        <a href="/"        class="px-4 py-2 rounded-full text-sm font-medium <%= path === '/' ? 'text-ink bg-card' : 'text-ink2 hover:text-ink hover:bg-card' %> transition">Beranda</a>
        <a href="/pricing" class="px-4 py-2 rounded-full text-sm font-medium <%= path === '/pricing' ? 'text-ink bg-card' : 'text-ink2 hover:text-ink hover:bg-card' %> transition">Paket</a>
        <a href="/#fitur"  class="px-4 py-2 rounded-full text-sm font-medium text-ink2 hover:text-ink hover:bg-card transition">Fitur</a>
        <a href="/#faq"    class="px-4 py-2 rounded-full text-sm font-medium text-ink2 hover:text-ink hover:bg-card transition">FAQ</a>
      </div>

      <div class="flex items-center gap-2">
        <% if (currentUser) { %>
          <% if (currentUser.role === 'admin') { %>
            <a href="/admin" class="hidden sm:inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium text-ink2 hover:text-ink hover:bg-card">
              <i class="fa-solid fa-shield-halved"></i> Admin
            </a>
          <% } %>
          <a href="/dashboard" class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium text-ink hover:bg-card">
            <i class="fa-solid fa-gauge-high"></i><span class="hidden sm:inline">Dashboard</span>
          </a>
          <form method="POST" action="/auth/logout" class="inline">
            <button class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium text-ink2 hover:text-danger hover:bg-card transition" type="submit">
              <i class="fa-solid fa-right-from-bracket"></i><span class="hidden sm:inline">Keluar</span>
            </button>
          </form>
        <% } else { %>
          <a href="/auth/login"    class="px-4 py-2 rounded-full text-sm font-medium text-ink2 hover:text-ink hover:bg-card">Masuk</a>
          <a href="/auth/register" class="px-4 py-2 rounded-full text-sm font-semibold text-white bg-brand shadow-glow hover:shadow-glowHover transition">Daftar</a>
        <% } %>
      </div>
    </div>
  </div>
</nav>
<div class="h-16"></div>
