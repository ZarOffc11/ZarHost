<nav class="fixed top-0 inset-x-0 z-50 backdrop-blur-2xl bg-bg/80 border-b border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- LEFT: Mobile hamburger (for sidebar) + logo -->
      <div class="flex items-center gap-2">
        <% if (typeof showSidebar !== 'undefined' && showSidebar) { %>
          <button id="nav-sidebar-toggle" type="button" class="lg:hidden p-2 rounded-lg text-ink2 hover:text-ink hover:bg-card2 transition" aria-label="Menu">
            <i class="fa-solid fa-bars text-lg"></i>
          </button>
        <% } %>
        <a href="/" class="flex items-center gap-2 group">
          <span class="w-9 h-9 rounded-xl bg-brand grid place-items-center shadow-glow group-hover:shadow-glowHover transition">
            <i class="fa-solid fa-cube text-white text-base"></i>
          </span>
          <span class="font-display font-extrabold text-xl text-ink tracking-tight hidden sm:block"><%= brand %></span>
        </a>
      </div>

      <!-- CENTER: Main nav (desktop only) -->
      <div class="hidden md:flex items-center gap-1">
        <a href="/"        class="px-4 py-2 rounded-full text-sm font-medium <%= path === '/' ? 'text-ink bg-card2 border border-border' : 'text-ink2 hover:text-ink hover:bg-card2' %> transition">Beranda</a>
        <a href="/pricing" class="px-4 py-2 rounded-full text-sm font-medium <%= path === '/pricing' ? 'text-ink bg-card2 border border-border' : 'text-ink2 hover:text-ink hover:bg-card2' %> transition">Paket</a>
        <a href="/#fitur"  class="px-4 py-2 rounded-full text-sm font-medium text-ink2 hover:text-ink hover:bg-card2 transition">Fitur</a>
        <a href="/#faq"    class="px-4 py-2 rounded-full text-sm font-medium text-ink2 hover:text-ink hover:bg-card2 transition">FAQ</a>
      </div>

      <!-- RIGHT: Profile / CTA -->
      <div class="flex items-center gap-2">
        <% if (currentUser) { %>
          <% if (currentUser.role === 'admin') { %>
            <a href="/admin" class="hidden md:inline-flex items-center gap-2 px-3 py-2 rounded-full text-xs font-semibold text-gold border border-gold/40 bg-gold/5 hover:bg-gold/10 transition">
              <i class="fa-solid fa-shield-halved"></i> <span class="hidden lg:inline">Admin</span>
            </a>
          <% } %>

          <!-- Avatar button + dropdown -->
          <div class="relative" id="nav-avatar-wrap">
            <button id="nav-avatar-btn" type="button" class="flex items-center gap-2 pl-1 pr-2 py-1 rounded-full border border-border bg-card2 hover:border-primary/50 transition">
              <img src="<%= currentUser.avatar %>" alt="avatar" class="w-8 h-8 rounded-full object-cover bg-card border border-border" referrerpolicy="no-referrer" />
              <span class="hidden sm:block text-sm font-medium text-ink max-w-[120px] truncate"><%= currentUser.name %></span>
              <i class="fa-solid fa-chevron-down text-xs text-ink2 pr-1"></i>
            </button>
            <div id="nav-avatar-menu" class="avatar-menu">
              <div class="p-4 border-b border-border flex items-center gap-3">
                <img src="<%= currentUser.avatar %>" alt="avatar" class="w-12 h-12 rounded-full object-cover bg-card border border-border" referrerpolicy="no-referrer" />
                <div class="min-w-0">
                  <div class="font-display font-semibold text-ink truncate"><%= currentUser.name %></div>
                  <div class="text-xs text-ink2 truncate"><%= currentUser.email %></div>
                  <% if (currentUser.role === 'admin') { %>
                    <span class="badge badge-gold mt-1"><i class="fa-solid fa-shield-halved text-[10px]"></i> Admin</span>
                  <% } %>
                </div>
              </div>
              <div class="p-2 space-y-0.5 text-sm">
                <a href="/dashboard" class="flex items-center gap-3 px-3 py-2 rounded-lg text-ink2 hover:text-ink hover:bg-card2 transition"><i class="fa-solid fa-gauge-high w-4 text-primary2"></i> Dashboard</a>
                <a href="/dashboard/hosting" class="flex items-center gap-3 px-3 py-2 rounded-lg text-ink2 hover:text-ink hover:bg-card2 transition"><i class="fa-solid fa-globe w-4 text-primary2"></i> Hosting Saya</a>
                <a href="/dashboard/history" class="flex items-center gap-3 px-3 py-2 rounded-lg text-ink2 hover:text-ink hover:bg-card2 transition"><i class="fa-solid fa-clock-rotate-left w-4 text-primary2"></i> Riwayat Transaksi</a>
                <a href="/dashboard/profile" class="flex items-center gap-3 px-3 py-2 rounded-lg text-ink2 hover:text-ink hover:bg-card2 transition"><i class="fa-solid fa-user w-4 text-primary2"></i> Profil</a>
                <% if (currentUser.role === 'admin') { %>
                  <a href="/admin" class="flex items-center gap-3 px-3 py-2 rounded-lg text-gold hover:bg-gold/10 transition"><i class="fa-solid fa-shield-halved w-4"></i> Admin Panel</a>
                <% } %>
                <div class="border-t border-border my-1"></div>
                <form method="POST" action="/auth/logout">
                  <button type="submit" class="w-full flex items-center gap-3 px-3 py-2 rounded-lg text-ink2 hover:text-danger hover:bg-danger/10 transition">
                    <i class="fa-solid fa-right-from-bracket w-4"></i> Keluar
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% } else { %>
          <a href="/auth/login"    class="px-4 py-2 rounded-full text-sm font-medium text-ink2 hover:text-ink hover:bg-card2 transition">Masuk</a>
          <a href="/auth/register" class="px-4 py-2 rounded-full text-sm font-semibold text-white bg-brand shadow-glow hover:shadow-glowHover transition">Daftar</a>
        <% } %>

        <!-- Mobile menu toggle (public pages only) -->
        <button id="nav-mobile-toggle" type="button" class="md:hidden p-2 rounded-lg text-ink2 hover:text-ink hover:bg-card2 transition" aria-label="Menu">
          <i class="fa-solid fa-bars text-lg"></i>
        </button>
      </div>
    </div>

    <!-- Mobile public nav -->
    <div id="nav-mobile" class="md:hidden hidden border-t border-border py-3 space-y-1">
      <a href="/"        class="block px-3 py-2 rounded-lg text-sm font-medium <%= path === '/' ? 'text-ink bg-card2' : 'text-ink2 hover:text-ink hover:bg-card2' %>">Beranda</a>
      <a href="/pricing" class="block px-3 py-2 rounded-lg text-sm font-medium <%= path === '/pricing' ? 'text-ink bg-card2' : 'text-ink2 hover:text-ink hover:bg-card2' %>">Paket</a>
      <a href="/#fitur"  class="block px-3 py-2 rounded-lg text-sm font-medium text-ink2 hover:text-ink hover:bg-card2">Fitur</a>
      <a href="/#faq"    class="block px-3 py-2 rounded-lg text-sm font-medium text-ink2 hover:text-ink hover:bg-card2">FAQ</a>
    </div>
  </div>
</nav>
<div class="h-16"></div>

<script>
  (function () {
    // Avatar dropdown
    var btn  = document.getElementById('nav-avatar-btn');
    var menu = document.getElementById('nav-avatar-menu');
    if (btn && menu) {
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        menu.classList.toggle('open');
      });
      document.addEventListener('click', function (e) {
        if (!menu.contains(e.target) && !btn.contains(e.target)) menu.classList.remove('open');
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') menu.classList.remove('open');
      });
    }

    // Mobile public-nav toggle
    var mbtn = document.getElementById('nav-mobile-toggle');
    var mnav = document.getElementById('nav-mobile');
    if (mbtn && mnav) mbtn.addEventListener('click', function () { mnav.classList.toggle('hidden'); });
  })();
</script>
