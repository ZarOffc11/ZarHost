<%
  const _sidebarUserLinks = [
    { href: '/dashboard',         key: 'home',    icon: 'fa-house',               label: 'Dashboard' },
    { href: '/dashboard/hosting', key: 'hosting', icon: 'fa-globe',               label: 'Hosting Saya' },
    { href: '/dashboard/history', key: 'history', icon: 'fa-clock-rotate-left',   label: 'Riwayat Transaksi' },
    { href: '/dashboard/profile', key: 'profile', icon: 'fa-user',                label: 'Profil' },
    { href: '/pricing',           key: 'buy',     icon: 'fa-cart-plus',           label: 'Beli Paket Baru' },
  ];
%>

<!-- Desktop sidebar (sticky, always visible on lg+) -->
<aside class="hidden lg:block lg:sticky lg:top-20 self-start lg:w-64 shrink-0">
  <%- include('_sidebar_user_body', { links: _sidebarUserLinks }) %>
</aside>

<!-- Mobile drawer (toggled via nav hamburger) -->
<div id="sidebar-mobile" class="sidebar-mobile lg:hidden">
  <div class="backdrop" data-close-sidebar></div>
  <div class="panel">
    <div class="flex items-center justify-between mb-3">
      <a href="/" class="flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-brand grid place-items-center shadow-glow">
          <i class="fa-solid fa-cube text-white text-sm"></i>
        </span>
        <span class="font-display font-extrabold text-lg text-ink"><%= brand %></span>
      </a>
      <button type="button" data-close-sidebar class="p-2 rounded-lg text-ink2 hover:text-ink hover:bg-card2">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <%- include('_sidebar_user_body', { links: _sidebarUserLinks }) %>
  </div>
</div>

<script>
  (function () {
    var drawer = document.getElementById('sidebar-mobile');
    var trigger = document.getElementById('nav-sidebar-toggle');
    if (trigger && drawer) trigger.addEventListener('click', function () { drawer.classList.add('open'); });
    document.querySelectorAll('[data-close-sidebar]').forEach(function (el) {
      el.addEventListener('click', function () { drawer && drawer.classList.remove('open'); });
    });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') drawer && drawer.classList.remove('open'); });
  })();
</script>
