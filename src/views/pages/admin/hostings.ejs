<%- include('../../partials/head') %>
<body class="bg-bg text-ink font-body min-h-screen">
<%- include('../../partials/alert') %>
<%- include('../../partials/navbar') %>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex flex-col lg:flex-row gap-6">
    <%- include('../../partials/sidebar_admin') %>

    <div class="flex-1 space-y-5">
      <div data-aos="fade-up" class="rounded-2xl border border-border bg-card p-6 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
        <div>
          <h1 class="font-display font-extrabold text-2xl">Manajemen Hosting</h1>
          <p class="text-ink2 text-sm mt-1">Total <span class="text-ink"><%= hostings.length %></span> hosting.</p>
        </div>
        <form method="GET" class="flex items-center gap-2">
          <select name="status" class="rounded-full bg-card2 border border-border px-4 py-2 text-sm text-ink focus:outline-none focus:border-primary">
            <option value="">Semua Status</option>
            <% ['active','expired','suspended','pending','provision_failed'].forEach(function(s){ %>
              <option value="<%= s %>" <%= filterStatus===s ? 'selected' : '' %>><%= s %></option>
            <% }) %>
          </select>
          <button class="px-4 py-2 rounded-full bg-brand text-white text-sm shadow-glow hover:shadow-glowHover transition">Filter</button>
        </form>
      </div>

      <div data-aos="fade-up" class="rounded-2xl border border-border bg-card overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="text-left text-xs text-ink2 uppercase">
              <tr>
                <th class="px-5 py-3">Domain</th>
                <th class="px-5 py-3">User</th>
                <th class="px-5 py-3">Paket</th>
                <th class="px-5 py-3">Mulai</th>
                <th class="px-5 py-3">Expired</th>
                <th class="px-5 py-3">Status</th>
                <th class="px-5 py-3 text-right">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% if (!hostings.length) { %>
                <tr><td colspan="7" class="px-5 py-6 text-center text-ink2">Tidak ada hosting.</td></tr>
              <% } else { %>
                <% hostings.forEach(function(h){ %>
                  <tr class="border-t border-border">
                    <td class="px-5 py-3 font-medium"><%= h.domain %></td>
                    <td class="px-5 py-3 text-ink2"><%= h.user_name %><div class="text-xs"><%= h.user_email %></div></td>
                    <td class="px-5 py-3 text-ink2"><%= h.package_name %></td>
                    <td class="px-5 py-3 text-ink2 whitespace-nowrap"><%= h.started_at ? new Date(h.started_at).toLocaleDateString('id-ID') : '-' %></td>
                    <td class="px-5 py-3 text-ink2 whitespace-nowrap"><%= h.expired_at ? new Date(h.expired_at).toLocaleDateString('id-ID') : '-' %></td>
                    <td class="px-5 py-3"><%- include('../../partials/_status_badge', { status: h.status }) %></td>
                    <td class="px-5 py-3 text-right space-x-2 whitespace-nowrap">
                      <% if (h.status === 'provision_failed') { %>
                        <form method="POST" action="/admin/hostings/<%= h.id %>/retry" class="inline">
                          <button class="text-primary2 hover:underline text-xs"><i class="fa-solid fa-rotate-right"></i> Retry</button>
                        </form>
                      <% } %>
                      <% if (h.status === 'active') { %>
                        <form method="POST" action="/admin/hostings/<%= h.id %>/suspend" class="inline">
                          <button class="text-danger hover:underline text-xs"><i class="fa-solid fa-pause"></i> Suspend</button>
                        </form>
                      <% } %>
                      <% if (h.status === 'suspended' || h.status === 'expired') { %>
                        <form method="POST" action="/admin/hostings/<%= h.id %>/activate" class="inline">
                          <button class="text-emerald hover:underline text-xs"><i class="fa-solid fa-play"></i> Aktifkan</button>
                        </form>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('../../partials/scripts') %>
</body>
</html>
