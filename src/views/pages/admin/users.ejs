<%- include('../../partials/head') %>
<body class="bg-bg text-ink font-body min-h-screen">
<%- include('../../partials/alert') %>
<%- include('../../partials/navbar') %>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex flex-col lg:flex-row gap-6">
    <%- include('../../partials/sidebar_admin') %>

    <div class="flex-1 space-y-5">
      <div data-aos="fade-up" class="rounded-2xl border border-border bg-card p-6 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
        <div>
          <h1 class="font-display font-extrabold text-2xl">Manajemen User</h1>
          <p class="text-ink2 text-sm mt-1">Total <span class="text-ink"><%= users.length %></span> user.</p>
        </div>
        <form method="GET" class="flex items-center gap-2">
          <div class="flex items-center rounded-full bg-card2 border border-border px-3 py-1">
            <i class="fa-solid fa-magnifying-glass text-ink2 text-sm"></i>
            <input name="q" value="<%= q %>" placeholder="Cari email atau nama"
                   class="bg-transparent px-2 py-1 text-sm focus:outline-none w-56" />
          </div>
          <button class="px-4 py-2 rounded-full bg-brand text-white text-sm shadow-glow hover:shadow-glowHover transition">Cari</button>
        </form>
      </div>

      <div data-aos="fade-up" class="rounded-2xl border border-border bg-card overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="text-left text-xs text-ink2 uppercase">
              <tr><th class="px-5 py-3">Nama</th><th class="px-5 py-3">Email</th><th class="px-5 py-3">Role</th><th class="px-5 py-3">Status</th><th class="px-5 py-3">Daftar</th><th class="px-5 py-3 text-right">Aksi</th></tr>
            </thead>
            <tbody>
              <% if (!users.length) { %>
                <tr><td colspan="6" class="px-5 py-6 text-center text-ink2">Tidak ada user.</td></tr>
              <% } else { %>
                <% users.forEach(function(u){ %>
                  <tr class="border-t border-border">
                    <td class="px-5 py-3 font-medium"><%= u.name %></td>
                    <td class="px-5 py-3 text-ink2"><%= u.email %></td>
                    <td class="px-5 py-3">
                      <% if (u.role === 'admin') { %><span class="badge badge-info"><i class="fa-solid fa-shield-halved"></i> Admin</span>
                      <% } else { %><span class="badge badge-muted">User</span><% } %>
                    </td>
                    <td class="px-5 py-3">
                      <% if (u.status === 'suspended') { %><span class="badge badge-danger"><i class="fa-solid fa-ban"></i> Suspended</span>
                      <% } else { %><span class="badge badge-success"><i class="fa-solid fa-circle-check"></i> Aktif</span><% } %>
                    </td>
                    <td class="px-5 py-3 text-ink2 whitespace-nowrap"><%= new Date(u.created_at).toLocaleDateString('id-ID') %></td>
                    <td class="px-5 py-3 text-right">
                      <% if (u.id !== currentUser.id) { %>
                        <form method="POST" action="/admin/users/<%= u.id %>/toggle" class="inline">
                          <button class="text-primary2 hover:underline text-xs">
                            <%= u.status === 'suspended' ? 'Aktifkan' : 'Suspend' %>
                          </button>
                        </form>
                      <% } else { %><span class="text-muted text-xs">(Anda)</span><% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('../../partials/scripts') %>
</body>
</html>
