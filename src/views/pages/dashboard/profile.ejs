<%- include('../../partials/head') %>
<body class="bg-bg text-ink font-body min-h-screen">
<%- include('../../partials/alert') %>
<%- include('../../partials/navbar') %>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex flex-col lg:flex-row gap-6">
    <%- include('../../partials/sidebar_user') %>

    <div class="flex-1 space-y-5 max-w-2xl">
      <div data-aos="fade-up" class="rounded-2xl border border-border bg-card p-6">
        <h1 class="font-display font-extrabold text-2xl">Profil</h1>
        <p class="text-ink2 text-sm mt-1">Edit informasi akun & ganti password.</p>
      </div>

      <% if (errors && errors.length) { %>
        <div class="rounded-xl border border-danger/40 bg-danger/10 p-3 text-sm text-danger">
          <ul class="list-disc pl-4 space-y-1">
            <% errors.forEach(function(e){ %><li><%= e.msg %></li><% }) %>
          </ul>
        </div>
      <% } %>

      <form method="POST" data-aos="fade-up" class="rounded-2xl border border-border bg-card p-6 space-y-5">
        <div>
          <label class="text-xs text-ink2 uppercase tracking-wide">Nama</label>
          <input name="name" type="text" required minlength="2" value="<%= currentUser.name %>"
                 class="mt-1 w-full rounded-xl bg-card2 border border-border px-4 py-3 text-sm focus:border-primary focus:outline-none" />
        </div>
        <div>
          <label class="text-xs text-ink2 uppercase tracking-wide">Email (read-only)</label>
          <input type="email" disabled value="<%= currentUser.email %>"
                 class="mt-1 w-full rounded-xl bg-card2/60 border border-border px-4 py-3 text-sm text-ink2 cursor-not-allowed" />
        </div>
        <div>
          <label class="text-xs text-ink2 uppercase tracking-wide">Tanggal Daftar</label>
          <input type="text" disabled value="<%= new Date(currentUser.created_at).toLocaleString('id-ID') %>"
                 class="mt-1 w-full rounded-xl bg-card2/60 border border-border px-4 py-3 text-sm text-ink2 cursor-not-allowed" />
        </div>

        <hr class="border-border" />
        <h3 class="font-display font-bold">Ganti Password (opsional)</h3>

        <div>
          <label class="text-xs text-ink2 uppercase tracking-wide">Password Lama</label>
          <input name="current_password" type="password" autocomplete="current-password"
                 class="mt-1 w-full rounded-xl bg-card2 border border-border px-4 py-3 text-sm focus:border-primary focus:outline-none" />
        </div>
        <div>
          <label class="text-xs text-ink2 uppercase tracking-wide">Password Baru</label>
          <input name="new_password" type="password" minlength="6" autocomplete="new-password"
                 class="mt-1 w-full rounded-xl bg-card2 border border-border px-4 py-3 text-sm focus:border-primary focus:outline-none" />
        </div>
        <div>
          <label class="text-xs text-ink2 uppercase tracking-wide">Konfirmasi Password Baru</label>
          <input name="confirm_password" type="password" minlength="6" autocomplete="new-password"
                 class="mt-1 w-full rounded-xl bg-card2 border border-border px-4 py-3 text-sm focus:border-primary focus:outline-none" />
        </div>

        <div class="flex justify-end">
          <button class="px-6 py-3 rounded-full bg-brand text-white font-semibold shadow-glow hover:shadow-glowHover transition text-sm">
            <i class="fa-solid fa-floppy-disk mr-1"></i> Simpan
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<%- include('../../partials/scripts') %>
</body>
</html>
