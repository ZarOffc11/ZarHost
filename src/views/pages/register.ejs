<%- include('../partials/head') %>
<body class="bg-bg text-ink font-body min-h-screen relative">
<%- include('../partials/alert') %>
<%- include('../partials/navbar') %>

<section class="max-w-md mx-auto px-4 py-16">
  <div class="rounded-2xl border border-border bg-card/80 backdrop-blur-xl p-8 shadow-glow" data-aos="zoom-in">
    <div class="text-center mb-6">
      <div class="w-14 h-14 mx-auto rounded-2xl bg-brand grid place-items-center shadow-glow mb-3">
        <i class="fa-solid fa-user-plus text-white text-xl"></i>
      </div>
      <h1 class="font-display font-extrabold text-2xl">Buat Akun Baru</h1>
      <p class="text-ink2 text-sm mt-1">Gratis & cepat — siap jualan website dalam menit.</p>
    </div>

    <% if (errors && errors.length) { %>
      <div class="mb-4 rounded-xl border border-danger/40 bg-danger/10 p-3 text-sm text-danger">
        <ul class="list-disc pl-4 space-y-1">
          <% errors.forEach(function(e){ %><li><%= e.msg %></li><% }) %>
        </ul>
      </div>
    <% } %>

    <form method="POST" action="/auth/register" class="space-y-4">
      <div>
        <label class="text-xs text-ink2 uppercase tracking-wide">Nama Lengkap</label>
        <div class="mt-1 flex items-center rounded-xl border border-border bg-card2 focus-within:border-primary transition">
          <span class="px-3 text-ink2"><i class="fa-solid fa-user"></i></span>
          <input name="name" type="text" required minlength="2" value="<%= formData.name || '' %>"
                 class="flex-1 bg-transparent py-3 text-sm placeholder-muted focus:outline-none" placeholder="Nama Anda" />
        </div>
      </div>
      <div>
        <label class="text-xs text-ink2 uppercase tracking-wide">Email</label>
        <div class="mt-1 flex items-center rounded-xl border border-border bg-card2 focus-within:border-primary transition">
          <span class="px-3 text-ink2"><i class="fa-solid fa-envelope"></i></span>
          <input name="email" type="email" required value="<%= formData.email || '' %>"
                 class="flex-1 bg-transparent py-3 text-sm placeholder-muted focus:outline-none" placeholder="anda@email.com" />
        </div>
      </div>
      <div>
        <label class="text-xs text-ink2 uppercase tracking-wide">Password</label>
        <div class="mt-1 flex items-center rounded-xl border border-border bg-card2 focus-within:border-primary transition">
          <span class="px-3 text-ink2"><i class="fa-solid fa-lock"></i></span>
          <input id="reg-password" name="password" type="password" required minlength="6"
                 class="flex-1 bg-transparent py-3 text-sm placeholder-muted focus:outline-none" placeholder="Minimal 6 karakter" />
          <button type="button" data-toggle-pass="reg-password" class="px-3 text-ink2 hover:text-ink"><i class="fa-regular fa-eye"></i></button>
        </div>
      </div>
      <div>
        <label class="text-xs text-ink2 uppercase tracking-wide">Konfirmasi Password</label>
        <div class="mt-1 flex items-center rounded-xl border border-border bg-card2 focus-within:border-primary transition">
          <span class="px-3 text-ink2"><i class="fa-solid fa-lock"></i></span>
          <input id="reg-cpassword" name="confirm_password" type="password" required minlength="6"
                 class="flex-1 bg-transparent py-3 text-sm placeholder-muted focus:outline-none" placeholder="Ulangi password" />
          <button type="button" data-toggle-pass="reg-cpassword" class="px-3 text-ink2 hover:text-ink"><i class="fa-regular fa-eye"></i></button>
        </div>
      </div>
      <button class="w-full inline-flex items-center justify-center gap-2 py-3 rounded-full bg-brand text-white font-semibold shadow-glow hover:shadow-glowHover transition">
        <i class="fa-solid fa-user-plus"></i> Daftar
      </button>
    </form>

    <p class="text-center text-sm text-ink2 mt-5">
      Sudah punya akun? <a href="/auth/login" class="text-primary2 hover:underline">Masuk di sini</a>
    </p>
  </div>
</section>

<%- include('../partials/footer') %>
<%- include('../partials/scripts') %>
</body>
</html>
